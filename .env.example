# Vercel Blob (auto-added when you link a Blob store to the project)
BLOB_READ_WRITE_TOKEN=

# Admin sign-in
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Signs the HTTP-only session cookie (16+ characters; never exposed to the public site)
AUTH_SECRET=use-openssl-or-node-to-generate-a-long-random-string

# Optional: "private" (default) or "public" — must match how blobs were uploaded.
# CAS_BLOB_ACCESS=public
